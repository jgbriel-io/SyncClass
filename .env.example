# Supabase Configuration
# Obtenha suas chaves em: https://supabase.com/dashboard/project/[PROJECT_ID]/settings/api

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key-here"

# IMPORTANTE: NUNCA commite o arquivo .env com suas credenciais reais
# Para uso local: copie este arquivo para .env e preencha com suas chaves reais
