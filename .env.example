# Supabase Configuration
# Obtenha suas chaves em: https://supabase.com/dashboard/project/[PROJECT_ID]/settings/api

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key-here"

# Sentry Configuration (opcional)
# Obtenha seu DSN em: https://sentry.io/settings/[ORG]/projects/[PROJECT]/keys/
VITE_SENTRY_DSN=""
VITE_ENVIRONMENT="development"

# PIX (opcional) - Chave PIX ou string "copia e cola" exibida ao aluno na aba Financeiro quando há cobranças pendentes.
# Fluxo manual: aluno paga, envia comprovante ao professor, que altera o status na plataforma.
# VITE_PIX_KEY="sua-chave-pix-ou-copia-e-cola"

# IMPORTANTE: NUNCA commite o arquivo .env com suas credenciais reais
# Para uso local: copie este arquivo para .env e preencha com suas chaves reais
